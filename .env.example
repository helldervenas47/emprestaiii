# =====================================================================
# .env.example — placeholders only. Copy to `.env` for local dev if you
# are NOT running on Lovable Cloud (Cloud auto-generates the real .env).
#
# Apenas chaves PUBLISHABLE/ANON ficam aqui. Segredos reais
# (service_role, tokens Telegram/WhatsApp, OpenAI/Gemini, Stripe secret,
# Asaas secret, Mercado Pago secret etc.) NUNCA vão em .env — eles são
# configurados como Edge Function Secrets no painel do backend.
# =====================================================================

# Lovable Cloud (Supabase gerenciado)
VITE_SUPABASE_URL="https://<project-ref>.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="<anon-publishable-key>"
VITE_SUPABASE_PROJECT_ID="<project-ref>"

# Supabase externo (legado, opcional)
VITE_EXTERNAL_SUPABASE_URL="https://<external-ref>.supabase.co"
VITE_EXTERNAL_SUPABASE_ANON_KEY="<external-anon-key>"

# Asaas — client token público (sandbox em .env.development, produção em .env.production)
VITE_PAYMENTS_CLIENT_TOKEN="test_xxxxxxxxxxxxxxxxxxxx"
