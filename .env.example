# =====================================================================
# .env.example — placeholders only. Copy to `.env` for local dev if you
# are NOT running on Lovable Cloud (Cloud auto-generates the real .env).
#
# Apenas chaves PUBLISHABLE/ANON ficam aqui. Segredos reais
# (service_role, tokens Telegram/WhatsApp, OpenAI/Gemini, Stripe secret,
# Asaas secret, Mercado Pago secret etc.) NUNCA vão em .env — eles são
# configurados como Edge Function Secrets no painel do backend.
# =====================================================================

# Supabase externo (banco oficial do app) — OBRIGATÓRIAS.
# - Local: copie este arquivo para `.env` (não versionado) e preencha.
# - Vercel: configure em Project Settings → Environment Variables
#   (Production + Preview). Sem elas, o app exibe a tela
#   "Configuração incompleta" — comportamento correto e intencional.
# - Lovable Preview: a plataforma não injeta variáveis VITE_* customizadas
#   no build do Preview, então a tela "Configuração incompleta" é
#   esperada ali. Use Vercel para testes reais end-to-end.
VITE_EXTERNAL_SUPABASE_URL=
VITE_EXTERNAL_SUPABASE_ANON_KEY=

# Lovable Cloud (Supabase gerenciado — atualmente ocioso, mantido apenas
# para compatibilidade com o client auto-gerado)
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=https://syyxnqzxqabeuqbuptkh.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InN5eXhucXp4cWFiZXVxYnVwdGtoIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODAzNjEwNTEsImV4cCI6MjA5NTkzNzA1MX0.cHrLm6A5Ym4PNGQ5q1XQt3_XEQZSSH-5kQxB5axZSkc
SUPABASE_PROJECT_REF=

# Asaas — client token público (sandbox em dev, produção em prod)
VITE_PAYMENTS_CLIENT_TOKEN=
